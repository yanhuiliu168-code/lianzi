.container {
  padding: 20px;
}

.header {
  text-align: center;
  margin-bottom: 30px;
}

.title {
  display: block;
  font-size: 24px;
  color: #1890ff;
  font-weight: bold;
  margin-bottom: 10px;
}

.subtitle {
  font-size: 14px;
  color: #666;
}

.control-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30px;
}

.input-group {
  display: flex;
  width: 100%;
  justify-content: center;
  align-items: center;
}

.char-input {
  border: 1px solid #d9d9d9;
  border-radius: 4px;
  height: 40px;
  padding: 0 10px;
  flex: 1;
  max-width: 200px;
  margin-right: 10px;
  text-align: center;
}

.generate-btn {
  background-color: #1890ff;
  color: #fff;
  height: 40px;
  line-height: 40px;
  font-size: 16px;
  margin: 0;
  padding: 0 20px;
}

.error-msg {
  color: #ff4d4f;
  font-size: 12px;
  margin-top: 10px;
}

.animation-section {
  background: #fff;
  border-radius: 8px;
  padding: 20px;
  text-align: center;
  margin-bottom: 20px;
}

.section-title {
  font-size: 16px;
  color: #333;
  margin-bottom: 15px;
  font-weight: bold;
}

.writer-canvas {
  width: 150px;
  height: 150px;
  margin: 0 auto;
  border: 1px solid #eee;
  background-color: #fff;
}

.animate-btn {
  margin-top: 15px;
  font-size: 14px;
  background-color: #f0f0f0;
}

.worksheet-section {
  background: #fff;
  border-radius: 8px;
  padding: 20px;
  text-align: center;
}

.tips {
  font-size: 12px;
  color: #999;
  margin-bottom: 15px;
}

.export-btn {
  background-color: #52c41a;
  color: #fff;
  font-size: 16px;
}